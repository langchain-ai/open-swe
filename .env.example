# === Runtime ===
SANDBOX_TYPE="local"
LANGGRAPH_URL="http://localhost:2024"
LOCAL_SANDBOX_ROOT_DIR="${HOME}/.open-swe-local-sandbox"

# === LangSmith sandbox + tracing ===
# Not required for the local OpenAI POC. Leave empty unless you want LangSmith tracing.
LANGSMITH_API_KEY_PROD=""
LANGSMITH_TENANT_ID_PROD=""
LANGSMITH_TRACING_PROJECT_ID_PROD=""
LANGCHAIN_TRACING_V2="false"
LANGCHAIN_PROJECT="open-swe-github-poc"

# === LLM ===
# Pick any provider/model supported by your local credentials.
# Examples:
#   LLM_MODEL_ID="openai:gpt-5"
#   LLM_MODEL_ID="openai:gpt-4.1"
#   LLM_MODEL_ID="anthropic:claude-opus-4-6"
LLM_MODEL_ID="openai:gpt-5"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# === GitHub App ===
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=""
GITHUB_WEBHOOK_SECRET=""

# Leave GitHub OAuth disabled in the GitHub-only POC.
# When empty, the app runs in bot-token-only mode.
GITHUB_OAUTH_PROVIDER_ID=""

# === GitHub-only POC guardrails ===
ALLOWED_GITHUB_ORGS="my-org"
ALLOWED_GITHUB_REPOS="my-org/my-repo"
DEFAULT_REPO_OWNER="my-org"
DEFAULT_REPO_NAME="my-repo"
GITHUB_USER_EMAIL_MAP_JSON="{\"octocat\":\"octocat@example.com\"}"

# === Optional ===
EXA_API_KEY=""
TOKEN_ENCRYPTION_KEY=""
