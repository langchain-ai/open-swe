# Hermes Northstar Agent Harness - placeholder-only example
# Copy to .env only in an isolated local dev/testrepo environment.
# Do not paste real values into this example file.

# === Local harness mode ===
HERMES_HARNESS_MODE="local-dev-no-webhooks"
ALLOW_BOOTSTRAP_INSTALL="NO"
ALLOW_WEBHOOK_SETUP="NO"
ALLOW_GITHUB_APP_SETUP="NO"
ALLOW_PROD_INSTALL="NO"
ALLOW_DOCKER_BUILD="NO"
ALLOW_NORTHSTAR_REPO="NO"
REPO_ALLOWLIST_FAIL_CLOSED="true"
DEFAULT_REPO_OWNER="example-owner"
DEFAULT_REPO_NAME="example-testrepo"
ALLOWED_GITHUB_REPOS="example-owner/example-testrepo"
ALLOWED_GITHUB_ORGS=""
ALLOWED_REVIEWER_GITHUB_REPOS="example-owner/example-testrepo"
ALLOWED_REVIEWER_GITHUB_ORGS=""
PUBLIC_REPO_ORG_GATE=""
DISABLED_WEBHOOKS="slack,linear"
DISABLED_AGENT_TOOLS="http_request,fetch_url,web_search,linear_comment,linear_create_issue,linear_delete_issue,linear_get_issue,linear_get_issue_comments,linear_list_teams,linear_update_issue,slack_read_thread_messages,slack_thread_reply"

# === Sandbox ===
# Autonomous Northstar runs require an isolated cloud/container sandbox.
# For this local dev bootstrap, do not start runtime/webhooks without separate approval.
SANDBOX_TYPE="langsmith"
DEFAULT_SANDBOX_SNAPSHOT_ID="REPLACE_WITH_TEST_SANDBOX_SNAPSHOT_ID"
DEFAULT_SANDBOX_SNAPSHOT_FS_CAPACITY_BYTES="34359738368"
DEFAULT_SANDBOX_VCPUS="4"
DEFAULT_SANDBOX_MEM_BYTES="16106127360"
DEFAULT_SANDBOX_IDLE_TTL_SECONDS="600"
DEFAULT_SANDBOX_DELETE_AFTER_STOP_SECONDS="86400"

# === LangSmith placeholders ===
LANGSMITH_API_KEY_PROD="REPLACE_WITH_TEST_LANGSMITH_API_KEY"
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_PROJECT="hermes-northstar-agent-harness-test"
LANGSMITH_TENANT_ID_PROD="REPLACE_WITH_TEST_LANGSMITH_TENANT_ID"
LANGSMITH_TRACING_PROJECT_ID_PROD="REPLACE_WITH_TEST_TRACING_PROJECT_ID"
LANGSMITH_URL_PROD="https://smith.langchain.com"
LANGGRAPH_URL_PROD="http://127.0.0.1:2024"

# === LLM placeholders ===
ANTHROPIC_API_KEY="REPLACE_WITH_TEST_ANTHROPIC_API_KEY"
OPENAI_API_KEY="REPLACE_WITH_TEST_OPENAI_API_KEY"
GOOGLE_API_KEY="REPLACE_WITH_TEST_GOOGLE_API_KEY"
LLM_FALLBACK_MODEL_ID=""

# === GitHub App placeholders - do not create/use without separate approval ===
GITHUB_APP_ID="REPLACE_WITH_TEST_GITHUB_APP_ID"
GITHUB_APP_PRIVATE_KEY="REPLACE_WITH_TEST_PRIVATE_KEY_PLACEHOLDER_ONLY"
GITHUB_APP_INSTALLATION_ID="REPLACE_WITH_TEST_INSTALLATION_ID"
GITHUB_WEBHOOK_SECRET="REPLACE_WITH_TEST_WEBHOOK_SECRET"
GITHUB_OAUTH_PROVIDER_ID="REPLACE_WITH_TEST_OAUTH_PROVIDER_ID"
GITHUB_APP_CLIENT_ID="REPLACE_WITH_TEST_CLIENT_ID"
GITHUB_APP_CLIENT_SECRET="REPLACE_WITH_TEST_CLIENT_SECRET"

# === Dashboard placeholders ===
DASHBOARD_BASE_URL="http://127.0.0.1:2024"
DASHBOARD_API_BASE_URL="http://127.0.0.1:2024"
DASHBOARD_ALLOWED_ORIGINS="http://127.0.0.1:2024,http://localhost:2024"
DASHBOARD_JWT_SECRET="REPLACE_WITH_TEST_DASHBOARD_JWT_SECRET"
CONFIGURED_ADMINS="example-admin@example.invalid"

# === Disabled optional integrations for initial harness ===
LINEAR_API_KEY=""
LINEAR_WEBHOOK_SECRET=""
SLACK_BOT_TOKEN=""
SLACK_BOT_USER_ID=""
SLACK_BOT_USERNAME=""
SLACK_SIGNING_SECRET=""
EXA_API_KEY=""

# === Token encryption placeholder ===
TOKEN_ENCRYPTION_KEY="REPLACE_WITH_TEST_FERNET_KEY"
