# ============================================================
# Open SWE — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# See INSTALLATION.md for detailed setup instructions.
# ============================================================


# === LangSmith (required) ===
# Tracing and sandbox infrastructure. See INSTALLATION.md step 4.
LANGSMITH_API_KEY_PROD=""              # Settings > API Keys > Create API Key
LANGCHAIN_TRACING_V2="true"
LANGCHAIN_PROJECT=""                   # LangSmith project name for traces
LANGSMITH_TENANT_ID_PROD=""            # UUID from your LangSmith URL
LANGSMITH_TRACING_PROJECT_ID_PROD=""   # Project ID (click ID button next to project name)
LANGSMITH_URL_PROD="https://smith.langchain.com"


# === LLM (required) ===
ANTHROPIC_API_KEY=""                   # https://console.anthropic.com/settings/keys
# LLM_MODEL_ID="anthropic:claude-opus-4-6"  # Override the default model


# === GitHub App (required) ===
# See INSTALLATION.md step 3 for creating the GitHub App.
GITHUB_APP_ID=""                       # App settings page, top of the page
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...paste your full private key here...
-----END RSA PRIVATE KEY-----"
GITHUB_APP_INSTALLATION_ID=""          # Number at end of installation URL
GITHUB_WEBHOOK_SECRET=""               # Generate with: openssl rand -hex 32


# === GitHub OAuth via LangSmith (optional) ===
# Without this, all operations use the GitHub App bot token.
# With this, each user authenticates with their own GitHub account.
# See INSTALLATION.md step 4b.
GITHUB_OAUTH_PROVIDER_ID=""            # Must match the provider ID in LangSmith


# === Org Allowlist & Default Repository ===
ALLOWED_GITHUB_ORGS=""                 # Comma-separated, e.g. "my-org,my-other-org"
DEFAULT_REPO_OWNER=""                  # Default GitHub org (e.g. "my-org")
DEFAULT_REPO_NAME=""                   # Default GitHub repo (e.g. "my-repo")


# === Linear (optional) ===
# See INSTALLATION.md step 5 (Linear section).
LINEAR_API_KEY=""                      # Settings > API > Personal API keys
LINEAR_WEBHOOK_SECRET=""               # Generate with: openssl rand -hex 32


# === Slack (optional) ===
# See INSTALLATION.md step 5 (Slack section).
SLACK_BOT_TOKEN=""                     # Bot User OAuth Token (xoxb-...)
SLACK_BOT_USER_ID=""                   # Bot's Slack user ID
SLACK_BOT_USERNAME=""                  # Bot's display name (e.g. "open-swe")
SLACK_SIGNING_SECRET=""                # Basic Information > App Credentials
# Override default repo for Slack messages (falls back to DEFAULT_REPO_OWNER/NAME):
# SLACK_REPO_OWNER=""
# SLACK_REPO_NAME=""


# === Web Search (optional) ===
# Enables the Exa web search tool.
EXA_API_KEY=""                         # https://dashboard.exa.ai


# === Sandbox (optional) ===
# Controls the isolated execution environment for each agent run.
# See INSTALLATION.md step 4c and CUSTOMIZATION.md for details.
# SANDBOX_TYPE="langsmith"             # Options: langsmith, modal, daytona, runloop, local
# DEFAULT_SANDBOX_TEMPLATE_NAME=""     # Custom sandbox template name
# DEFAULT_SANDBOX_TEMPLATE_IMAGE=""    # Custom Docker image (default: python:3)
# RUNLOOP_API_KEY=""                   # Required if SANDBOX_TYPE=runloop
# DAYTONA_API_KEY=""                   # Required if SANDBOX_TYPE=daytona
# MODAL_APP_NAME="open-swe"           # Required if SANDBOX_TYPE=modal
# LOCAL_SANDBOX_ROOT_DIR=""            # Required if SANDBOX_TYPE=local


# === Token Encryption (required) ===
TOKEN_ENCRYPTION_KEY=""                # Generate with: openssl rand -base64 32
