# Overrides layered on top of .env when the e2e test suite runs
# (see `make test-e2e`). Keeps .env useful for real interactive dev while
# tests stay hermetic.
#
# Fake API key — the SDK requires the header to be present, but fake-deps'
# scripted proxy ignores its contents.
ANTHROPIC_API_KEY=sk-ant-fake-dev-key

# Route the anthropic SDK at fake-deps' /anthropic proxy. It returns whatever
# the test has pre-registered via `POST /anthropic/ui/script` keyed by a
# `test_id` that appears in the request body. No upstream; no recording.
# See hack/fake_deps/llm.py.
ANTHROPIC_BASE_URL=http://localhost:13765/anthropic

# Route GitHub API at fake-deps' /github/api mock. Interactive `make dev`
# leaves this unset so the agent hits real github.com with GITHUB_PAT.
GITHUB_API_BASE_URL=http://localhost:13765/github/api
