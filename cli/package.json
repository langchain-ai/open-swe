{
  "name": "open-swe-cli",
  "version": "0.1.0",
  "packageManager": "bun",
  "description": "Open SWE CLI - Terminal client for the Open SWE remote agent server",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openswe": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json && chmod +x dist/index.js",
    "start": "bun run dist/index.js",
    "dev": "bun run index.ts",
    "watch": "tsc --watch",
    "test": "vitest run",
    "logs:tail": "tail -f ~/.openswe/logs/openswe.log"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^17.2.2",
    "ink": "^6.2.3",
    "ink-spinner": "^5.0.0",
    "open": "^10.1.0",
    "react": "^19.1.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^10.0.0",
    "yargs": "^17.7.2",
    "zod": "^4.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.11.24",
    "@types/react": "^19.1.8",
    "@types/yargs": "^17.0.32",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "eslint-plugin-unicorn": "^61.0.2",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^26.1.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.3.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20"
  }
}
