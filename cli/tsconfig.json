{
  "compilerOptions": {
    "module": "node16",
    "target": "es2022",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2023"],
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@tui/*": ["src/tui/*"],
      "@lib/*": ["src/lib/*"],
      "@lib/logger": ["src/lib/logger.ts"],
      "@lib/diff": ["src/lib/diff.ts"],
      "@lib/time": ["src/lib/time.ts"],
      "@lib/constants": ["src/lib/constants.ts"],
      "@lib/tool-result": ["src/lib/tool-result.ts"],
      "@lib/api-types": ["src/lib/api-types.ts"],
      "@lib/api-client": ["src/lib/api-client.ts"],
      "@lib/sse": ["src/lib/sse.ts"],
      "@lib/auth-flow": ["src/lib/auth-flow.ts"],
      "@lib/cli-args": ["src/lib/cli-args.ts"],
      "@lib/config": ["src/lib/config.ts"],
      "@lib/upgrade": ["src/lib/upgrade.ts"],
      "@lib/cursor-store": ["src/lib/cursor-store.ts"],
      "@config/*": ["src/config/*"],
      "@types": ["src/types/index.ts"],
      "@types/*": ["src/types/*"]
    }
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
