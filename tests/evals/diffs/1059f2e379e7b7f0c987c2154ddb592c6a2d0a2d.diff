 logger = structlog.get_logger(__name__)
 
+_ATTACHMENT_FETCH_TIMEOUT_SECONDS = 30
+
+
+async def _fetch_and_encode_attachment(
+    aclient: httpx.AsyncClient,
+    key: str,
+    presigned_url: str,
+    mime_type: str,
+) -> tuple[str, dict[str, str]] | None:
+    """Fetch a single presigned-URL attachment and return (key, {data, mime_type})."""
+    try:
+        response = await aclient.get(presigned_url)
+        response.raise_for_status()
+        content_type = response.headers.get("Content-Type", mime_type)
+        if not content_type or not is_supported_multimodal_mime_type(content_type):
+            return None
+
+        encoded = base64.b64encode(response.content).decode("utf-8")
+        if content_type.startswith("audio/"):
+            data = encoded
+        else:
+            data = f"data:{content_type};base64,{encoded}"
+        return key, {"data": data, "mime_type": content_type}
+    except httpx.HTTPError as e:
+        logger.error(
+            "Failed to fetch presigned attachment",
+            error=str(e),
+            key=key,
+        )
+        return None
+
+
+async def _resolve_presigned_attachments(
+    attachments: dict[str, Any] | None,
+) -> dict[str, Any]:
+    """Download presigned-URL attachments and convert to {data, mime_type} format.
+
+    The Go experiment service sends attachments as
+    {"presigned_url": "...", "mime_type": "...", "storage_url": "..."}.
+    The playground multimodal pipeline expects {"data": "<base64>", "mime_type": "..."}.
+    This bridges the two formats, mirroring smith-backend's format_attachment_urls.
+    """
+    if not attachments:
+        return {}
+
+    resolved: dict[str, Any] = {}
+    fetch_tasks: list[asyncio.Task] = []
+
+    async with httpx.AsyncClient(timeout=_ATTACHMENT_FETCH_TIMEOUT_SECONDS) as aclient:
+        for key, value in attachments.items():
+            if not isinstance(value, dict):
+                resolved[key] = value
+                continue
+
+            if "data" in value and "mime_type" in value:
+                resolved[key] = value
+                continue
+
+            presigned_url = value.get("presigned_url")
+            if not presigned_url:
+                resolved[key] = value
+                continue
+
+            fetch_tasks.append(
+                asyncio.create_task(
+                    _fetch_and_encode_attachment(
+                        aclient,
+                        key,
+                        presigned_url,
+                        value.get("mime_type", ""),
+                    )
+                )
+            )
+
+        if fetch_tasks:
+            results = await asyncio.gather(*fetch_tasks)
+            for result in results:
+                if result is not None:
+                    resolved[result[0]] = result[1]
+
+    return resolved
+
 
