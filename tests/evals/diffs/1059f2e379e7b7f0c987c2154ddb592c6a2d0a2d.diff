+// attachmentPrefix is the key prefix used in the attachment_urls JSONB column.
+const attachmentPrefix = "attachment."
+
+// sanitizeAttachmentKey converts a raw attachment_urls key (e.g.
+// "attachment.5872_BORK.png") into the template variable name expected by the
+// prompt (e.g. "5872_BORK_png"). This mirrors the frontend's
+// convertAttachmentNameToTemplateVar and the Python backend's
+// sanitize_attachment_name.
+func sanitizeAttachmentKey(key string) string {
+	key = strings.TrimPrefix(key, attachmentPrefix)
+	return strings.ReplaceAll(key, ".", "_")
+}
