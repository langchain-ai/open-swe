+
+func TestSanitizeAttachmentKey(t *testing.T) {
+	tests := []struct {
+		input    string
+		expected string
+	}{
+		{"attachment.5872_BORK.png", "5872_BORK_png"},
+		{"attachment.invoice.pdf", "invoice_pdf"},
+		{"image", "image"},
+		{"attachment.nested.dots.file.txt", "nested_dots_file_txt"},
+		{"no_prefix_just_dots.csv", "no_prefix_just_dots_csv"},
+	}
+
+	for _, tc := range tests {
+		t.Run(tc.input, func(t *testing.T) {
+			assert.Equal(t, tc.expected, sanitizeAttachmentKey(tc.input))
+		})
+	}
+}
